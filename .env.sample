# LinkDing Server Configuration
# ==============================

# REQUIRED: LinkDing server URL and API token
LINKDING_URL=http://127.0.0.1:9090
LINKDING_API_TOKEN=your_api_token_here

# Security Settings
# -----------------
# Enable destructive actions (add, update, delete, archive)
# Set to true to allow bookmark modifications
LINKDING_ENABLE_DESTRUCTIVE_ACTIONS=false

# SSL/TLS Configuration
# ---------------------
# Verify SSL/TLS certificates when connecting to your LinkDing instance.
# Default: true (recommended). Set to false ONLY for trusted local setups
# (e.g. self-signed certs). Disabling this exposes traffic to MITM attacks.
LINKDING_VERIFY_SSL=true

# Path to a custom CA bundle or certificate file (PEM format).
# Use this when your LinkDing instance uses a private/internal CA.
# Leave unset to use the system default CA bundle.
# LINKDING_SSL_CERT_PATH=/path/to/ca-bundle.pem

# Request Configuration
# ---------------------
# Request timeout in seconds (1-300, default: 30)
LINKDING_REQUEST_TIMEOUT=30

# Maximum number of retry attempts (0-10, default: 3)
LINKDING_MAX_RETRIES=3

# Connection Pool Settings
# ------------------------
# Maximum number of connections (1-1000, default: 100)
LINKDING_MAX_CONNECTIONS=100

# Maximum number of keepalive connections (1-100, default: 20)
LINKDING_MAX_KEEPALIVE_CONNECTIONS=20

# Keepalive expiry in seconds (1-300, default: 30)
LINKDING_KEEPALIVE_EXPIRY=30

# Rate Limiting
# -------------
# Number of calls allowed per period (1-10000, default: 100)
LINKDING_RATE_LIMIT_CALLS=100

# Rate limit period in seconds (1-3600, default: 60)
LINKDING_RATE_LIMIT_PERIOD=60

# Cache Settings
# --------------
# Cache TTL in seconds (0 to disable, max: 3600, default: 300)
LINKDING_CACHE_TTL=300

# Maximum cached entries before least-recently-used eviction (1-10000, default: 100)
LINKDING_CACHE_MAX_SIZE=100

# Logging Configuration
# ---------------------
# Enable debug logging (true/false, default: false)
LINKDING_DEBUG=false

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL, default: INFO)
LINKDING_LOG_LEVEL=INFO
